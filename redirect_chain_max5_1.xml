<VAST version="3.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="vast.xsd">
  <Ad id="redirect_chain_1">
    <Wrapper>
      <AdSystem version="1.0">AdServer</AdSystem>
      <VASTAdTagURI><![CDATA[https://raw.githubusercontent.com/fujikiku/vast-sample/refs/heads/main/redirect_chain_max5_2.xml]]></VASTAdTagURI>

      <Error><![CDATA[http://example.com/track/error?code=[ERRORCODE]&reason=[REASON]&step=1]]></Error>
      <Impression><![CDATA[http://example.com/track/impression?step=1]]></Impression>

      <Creatives>
        <Creative id="cr_wrapper_tracking" sequence="1">
          <Linear>
            <TrackingEvents>
              <Tracking event="start"><![CDATA[http://example.com/track/start?step=1]]></Tracking>
              <Tracking event="complete"><![CDATA[http://example.com/track/complete?step=1]]></Tracking>
            </TrackingEvents>
          </Linear>
        </Creative>
      </Creatives>
    </Wrapper>
  </Ad>
</VAST>
