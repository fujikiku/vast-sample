<VAST version="3.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="vast.xsd">
  <Ad id="streaks_companion_click_test">
    <InLine>
      <AdSystem version="1.0">AdServer</AdSystem>
      <AdTitle>コンパニオン広告検証用サンプル(HTMLリソース_パターン1)</AdTitle>

      <Error><![CDATA[http://example.com/error?code=[ERRORCODE]]]></Error>
      <Impression><![CDATA[http://example.com/track/impression]]></Impression>

      <Creatives>

        <Creative id="cr_linear" sequence="1">
          <Linear>
            <Duration>00:00:10</Duration>
            <MediaFiles>
              <MediaFile delivery="progressive" type="video/mp4" width="640" height="360">
                <![CDATA[https://test-videos.co.uk/vids/bigbuckbunny/mp4/h264/720/Big_Buck_Bunny_720_10s_1MB.mp4]]>
              </MediaFile>
            </MediaFiles>
          </Linear>
        </Creative>

        <Creative id="cr_companion" sequence="1">
          <CompanionAds>

            <Companion id="companion_html_300x250" width="300" height="250">
              <StaticResource creativeType="image/png">
                  <![CDATA[ https://pagead2.googlesyndication.com/simgad/4446644594546952943 ]]>
              </StaticResource>

              <TrackingEvents>
                <Tracking event="creativeView"><![CDATA[http://example.com/track/html_companion_view]]></Tracking>
              </TrackingEvents>

              <CompanionClickThrough>
                <![CDATA[https://www.google.com/?hl=ja]]>
              </CompanionClickThrough>

              <CompanionClickTracking>
                <![CDATA[https://ad-server.example.com/track/html_companion_click_success?cb=[TIMESTAMP]]]>
              </CompanionClickTracking>
            </Companion>

          </CompanionAds>
        </Creative>

      </Creatives>
    </InLine>
  </Ad>
</VAST>
